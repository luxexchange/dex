{
  "name": "@luxfi/dex",
  "version": "2.0.8",
  "description": "Lux DEX SDK - V4 CLOB precompiles, order book client, and routing",
  "license": "BSD-3-Clause",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client/index.d.ts",
      "import": "./dist/client/index.js"
    },
    "./router": {
      "types": "./dist/router/index.d.ts",
      "import": "./dist/router/index.js"
    },
    "./precompile": {
      "types": "./dist/precompile/index.d.ts",
      "import": "./dist/precompile/index.js"
    },
    "./hooks": {
      "types": "./dist/hooks/index.d.ts",
      "import": "./dist/hooks/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc",
    "test": "vitest run",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "viem": "^2.30.6",
    "wagmi": "^3.1.3",
    "zustand": "^5.0.5"
  },
  "devDependencies": {
    "@types/node": "^25.0.3",
    "@types/react": "^19.2.3",
    "typescript": "5.9.3",
    "vitest": "^4.0.16"
  },
  "peerDependencies": {
    "react": "19.2.5"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/luxexchange/dex.git"
  },
  "keywords": [
    "lux",
    "dex",
    "defi",
    "clob",
    "amm",
    "swap",
    "precompile"
  ],
  "private": false
}
